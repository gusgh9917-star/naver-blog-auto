# ==========================================
# 네이버 블로그 자동화 - 설정 파일 (무료 버전)
# 이 파일을 복사해서 .env 로 저장하고 값을 채워주세요
# ==========================================

# Google Gemini API 키 (글 작성용, 무료) - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=여기에_Gemini_API키_입력

# 네이버 개발자 API (정보 수집용, 무료) - https://developers.naver.com
NAVER_CLIENT_ID=여기에_네이버_Client_ID_입력
NAVER_CLIENT_SECRET=여기에_네이버_Client_Secret_입력

# 네이버 블로그 로그인 정보
NAVER_ID=여기에_네이버_아이디_입력
NAVER_PW=여기에_네이버_비밀번호_입력

# 블로그 아이디 (blog.naver.com/여기부분)
NAVER_BLOG_ID=여기에_블로그_아이디_입력
